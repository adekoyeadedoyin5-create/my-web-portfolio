  <label id="number-label">Age</label>
  <input id="number" type="number" placeholder="age" min="10" max="15">
  <select id="dropdown">
    <option value="option1">Good</option>
    <option value="option2">Better</option>
    <option value="option1">Best</option>
    <input type="radio"
     name="good" value="yes">Yes
    <input type="radio" name="good" value="no">No
    <input type="checkbox" value="good">Good
    <input type="checkbox" value="bad">Bad
    <textarea></textarea>
